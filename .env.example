# Pulse News Configuration
# Copy this file to .env and fill in your values.

# Required in production
PULSE_NEWS_ENVIRONMENT=development
PULSE_NEWS_SECRET_KEY=change-me-before-production

# Resend email delivery
PULSE_NEWS_RESEND_API_KEY=
PULSE_NEWS_RESEND_FROM_EMAIL=
PULSE_NEWS_RESEND_WEBHOOK_SECRET=

# Non-production only: explicit local simulation modes
# Leave unset/false for fail-closed behavior.
PULSE_NEWS_ALLOW_SIMULATED_AI_GENERATION=false
PULSE_NEWS_ALLOW_SIMULATED_EMAIL_DELIVERY=false

# AI provider keys (set the ones you use)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
